{
	"info": {
		"_postman_id": "miniprogram-api-collection",
		"name": "皮肤健康监测系统 - 小程序API",
		"description": "皮肤健康监测系统小程序端API接口集合\n\n基础URL: http://47.103.108.47:5000/api/miniprogram\n认证方式: JWT Token (Bearer)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://47.103.108.47:5000/api/miniprogram",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. 用户模块",
			"item": [
				{
					"name": "1.1 用户注册",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"test_user_{{timestamp}}\",\n    \"password\": \"123456\",\n    \"phone\": \"13800138000\",\n    \"nickname\": \"测试用户\",\n    \"avatar\": \"https://example.com/avatar.jpg\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/user/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"user",
								"register"
							]
						},
						"description": "创建新用户账号\n\n**请求参数**:\n- username: 用户名（唯一）\n- password: 密码（最少6位）\n- phone: 手机号\n- nickname: 昵称（可选）\n- avatar: 头像URL（可选）"
					},
					"response": []
				},
				{
					"name": "1.2 用户登录",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.success && jsonData.data.token) {",
									"        pm.environment.set(\"token\", jsonData.data.token);",
									"        console.log('Token已保存:', jsonData.data.token);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"test_user\",\n    \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/user/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"user",
								"login"
							]
						},
						"description": "用户登录获取JWT Token\n\n**重要**: 登录成功后会自动保存Token到环境变量，后续请求会自动携带。"
					},
					"response": []
				},
				{
					"name": "1.3 获取个人信息",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/user/profile",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"user",
								"profile"
							]
						},
						"description": "获取当前登录用户的个人信息\n\n**需要认证**: 是"
					},
					"response": []
				},
				{
					"name": "1.4 更新个人信息",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nickname\": \"新昵称\",\n    \"avatar\": \"https://example.com/new_avatar.jpg\",\n    \"gender\": \"male\",\n    \"age\": 25,\n    \"skin_type\": \"combination\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/user/profile",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"user",
								"profile"
							]
						},
						"description": "更新用户个人信息\n\n**可更新字段**:\n- nickname: 昵称\n- avatar: 头像URL\n- gender: 性别（male/female）\n- age: 年龄\n- skin_type: 肤质（oily/dry/combination/sensitive）"
					},
					"response": []
				}
			],
			"description": "用户注册、登录、信息管理相关接口"
		},
		{
