						"body": {
							"mode": "raw",
							"raw": "{\n    \"device_id\": \"DEV_001\",\n    \"device_name\": \"我的皮肤检测仪\",\n    \"location\": \"家中\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/device/bind",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"device",
								"bind"
							]
						},
						"description": "将设备绑定到当前用户\n\n**请求参数**:\n- device_id: 设备ID（必填）\n- device_name: 设备名称（可选）\n- location: 使用位置（可选）"
					},
					"response": []
				},
				{
					"name": "2.2 获取设备列表",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/device/list?page=1&per_page=20",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"device",
								"list"
							],
							"query": [
								{
									"key": "page",
									"value": "1",
									"description": "页码"
								},
								{
									"key": "per_page",
									"value": "20",
									"description": "每页数量"
								}
							]
						},
						"description": "获取当前用户绑定的设备列表\n\n**查询参数**:\n- page: 页码（默认1）\n- per_page: 每页数量（默认20）"
					},
					"response": []
				},
				{
					"name": "2.3 获取设备状态",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/device/status/DEV_001",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"device",
								"status",
								"DEV_001"
							]
